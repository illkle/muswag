{
  "name": "@muswag/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Muswag desktop application built with Electron and electron-vite.",
  "author": "Muswag",
  "type": "module",
  "main": "./out/main/index.js",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "pnpm with-env electron-vite dev",
    "build": "pnpm typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "dist": "pnpm build && electron-builder",
    "dist:mac": "pnpm build && electron-builder --mac",
    "dist:win": "pnpm build && electron-builder --win",
    "dist:linux": "pnpm build && electron-builder --linux",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --write src electron.vite.config.ts vite.config.ts tsconfig.json tsconfig.node.json",
    "format:check": "oxfmt --check src electron.vite.config.ts vite.config.ts tsconfig.json tsconfig.node.json",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run --passWithNoTests",
    "test:integration": "vitest run --passWithNoTests",
    "postinstall": "electron-builder install-app-deps",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/typed-ipc": "^1.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fluentui/react-context-selector": "^9.2.15",
    "@muswag/shared": "workspace:*",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/electron-db-sqlite-persistence": "^0.1.4",
    "@tanstack/node-db-sqlite-persistence": "^0.1.4",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-form": "^1.28.4",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-store": "^0.9.2",
    "@tanstack/react-virtual": "^3.13.22",
    "@tanstack/router-plugin": "^1.132.0",
    "@types/lodash-es": "^4.17.12",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-orm": "catalog:",
    "lodash-es": "^4.17.23",
    "lucide-react": "^0.545.0",
    "nitro": "3.0.1-alpha.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-scan": "^0.5.3",
    "react-virtuoso": "^4.18.3",
    "scheduler": "^0.27.0",
    "shadcn": "^3.8.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "use-context-selector": "^2.0.0",
    "usehooks-ts": "^3.1.1"
  },
  "devDependencies": {
    "@muswag/tsconfig": "workspace:*",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "dotenv": "^17.3.1",
    "electron": "^38.8.4",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5"
  }
}