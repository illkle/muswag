{
  "name": "@muswag/opensubsonic-types",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/generated.ts",
    "openapi/openapi.json"
  ],
  "scripts": {
    "generate": "openapi-typescript ./openapi/openapi.json -o ./src/generated.ts",
    "openapi:update": "bash ./scripts/openapi-update.sh",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "openapi-typescript": "^7.10.0",
    "vitest": "^3.2.4"
  }
}
