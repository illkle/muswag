{
  "name": "@muswag/tests",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:sync-benchmark": "MUSWAG_RUN_SYNC_BENCHMARK=1 vitest run --config vitest.integration.config.ts test/navidrome-sync-benchmark.integration.test.ts"
  },
  "dependencies": {
    "@muswag/shared": "workspace:*",
    "better-sqlite3-test": "npm:better-sqlite3@12.6.0",
    "drizzle-orm": "^0.44.6",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@muswag/tsconfig": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "testcontainers": "^11.5.1",
    "vitest": "^3.2.4"
  }
}