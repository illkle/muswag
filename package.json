{
  "name": "muswag",
  "private": true,
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:local:mac": "pnpm turbo run build --filter=@muswag/desktop && CSC_IDENTITY_AUTO_DISCOVERY=false pnpm --filter @muswag/desktop exec electron-builder --mac --dir --config.mac.identity=- --publish never",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "turbo": "^2.5.8",
    "typescript": "^5.9.2"
  }
}