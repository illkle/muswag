{
  "name": "muswag",
  "private": true,
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "generate:types": "turbo run generate --filter=@muswag/opensubsonic-types",
    "openapi:update": "turbo run openapi:update --filter=@muswag/opensubsonic-types"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "turbo": "^2.5.8",
    "typescript": "^5.9.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "cpu-features",
      "esbuild",
      "protobufjs",
      "ssh2"
    ]
  }
}
